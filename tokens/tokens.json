{
  "$description": "SYNK design tokens (DTCG format) — single source of truth. Build with: npm run build:tokens. Must stay in parity with src/tokens.js and src/tokens.css (the consumer-facing copies).",
  "color": {
    "brand": {
      "violet":  { "$type": "color", "$value": "#6C63FF" },
      "indigo":  { "$type": "color", "$value": "#8B5CF6" },
      "eclipse": { "$type": "color", "$value": "#0a0a0a" }
    },
    "surface": {
      "canvas":  { "$type": "color", "$value": "#0a0a0a" },
      "card":    { "$type": "color", "$value": "#171717" },
      "raised":  { "$type": "color", "$value": "#1f1f1f" },
      "overlay": { "$type": "color", "$value": "#262626" },
      "inset":   { "$type": "color", "$value": "#121212" }
    },
    "border": {
      "subtle":  { "$type": "color", "$value": "rgba(255,255,255,0.06)" },
      "default": { "$type": "color", "$value": "rgba(255,255,255,0.10)" },
      "strong":  { "$type": "color", "$value": "rgba(255,255,255,0.16)" }
    },
    "text": {
      "hi":       { "$type": "color", "$value": "#ededed" },
      "mid":      { "$type": "color", "$value": "#a3a3a3" },
      "dim":      { "$type": "color", "$value": "rgba(255,255,255,0.40)" },
      "onAccent": { "$type": "color", "$value": "#ffffff" }
    },
    "accent": {
      "base":  { "$type": "color", "$value": "#6C63FF" },
      "hover": { "$type": "color", "$value": "#7d75ff" },
      "press": { "$type": "color", "$value": "#5b52e6" },
      "ring":  { "$type": "color", "$value": "rgba(108,99,255,0.45)" },
      "wash":  { "$type": "color", "$value": "rgba(108,99,255,0.10)" }
    },
    "status": {
      "success": { "$type": "color", "$value": "#10b981" },
      "warning": { "$type": "color", "$value": "#fbbf24" },
      "danger":  { "$type": "color", "$value": "#ef4444" },
      "info":    { "$type": "color", "$value": "#60a5fa" }
    }
  },
  "gradient": {
    "primary":   { "$type": "gradient", "$value": "linear-gradient(90deg, #6C63FF 0%, #8B5CF6 100%)" },
    "spotlight": { "$type": "gradient", "$value": "linear-gradient(to bottom left, rgba(108,99,255,0.25), rgba(108,99,255,0.10), transparent)" },
    "fog":       { "$type": "gradient", "$value": "linear-gradient(to top, #0a0a0a 0%, rgba(10,10,10,0.5) 45%, transparent 100%)" }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "20px" },
    "6": { "$type": "dimension", "$value": "24px" },
    "8": { "$type": "dimension", "$value": "32px" },
    "10": { "$type": "dimension", "$value": "40px" },
    "16": { "$type": "dimension", "$value": "64px" }
  },
  "radius": {
    "sm":   { "$type": "dimension", "$value": "8px" },
    "md":   { "$type": "dimension", "$value": "12px" },
    "lg":   { "$type": "dimension", "$value": "16px" },
    "xl":   { "$type": "dimension", "$value": "24px" },
    "2xl":  { "$type": "dimension", "$value": "32px" },
    "pill": { "$type": "dimension", "$value": "100px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "font": {
    "family": {
      "sans": { "$type": "fontFamily", "$value": "'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif" }
    },
    "weight": {
      "regular":   { "$type": "fontWeight", "$value": 400 },
      "medium":    { "$type": "fontWeight", "$value": 500 },
      "semibold":  { "$type": "fontWeight", "$value": 600 },
      "bold":      { "$type": "fontWeight", "$value": 700 },
      "extrabold": { "$type": "fontWeight", "$value": 800 },
      "black":     { "$type": "fontWeight", "$value": 900 }
    },
    "size": {
      "cap":     { "$type": "dimension", "$value": "10px" },
      "eyebrow": { "$type": "dimension", "$value": "11px" },
      "xs":      { "$type": "dimension", "$value": "12px" },
      "sm":      { "$type": "dimension", "$value": "14px" },
      "base":    { "$type": "dimension", "$value": "16px" },
      "md":      { "$type": "dimension", "$value": "17px" },
      "lg":      { "$type": "dimension", "$value": "19px" },
      "xl":      { "$type": "dimension", "$value": "24px" },
      "2xl":     { "$type": "dimension", "$value": "32px" },
      "display": { "$type": "dimension", "$value": "44px" }
    },
    "leading": {
      "tight":  { "$type": "number", "$value": 1.1 },
      "snug":   { "$type": "number", "$value": 1.25 },
      "normal": { "$type": "number", "$value": 1.5 }
    },
    "tracking": {
      "tighter": { "$type": "dimension", "$value": "-0.03em" },
      "tight":   { "$type": "dimension", "$value": "-0.02em" },
      "normal":  { "$type": "dimension", "$value": "0" },
      "wide":    { "$type": "dimension", "$value": "0.05em" },
      "eyebrow": { "$type": "dimension", "$value": "0.08em" }
    }
  },
  "shadow": {
    "soft":      { "$type": "shadow", "$value": "0px 4px 14px 0px rgba(0,0,0,0.25)" },
    "deep":      { "$type": "shadow", "$value": "0px 10px 25px -5px rgba(0,0,0,0.5)" },
    "xl":        { "$type": "shadow", "$value": "0px 25px 50px -12px rgba(0,0,0,0.7)" },
    "glow":      { "$type": "shadow", "$value": "0px 0px 15px rgba(108,99,255,0.4)" },
    "glowStrong":{ "$type": "shadow", "$value": "0px 0px 30px rgba(108,99,255,0.5)" }
  },
  "blur": {
    "sm": { "$type": "dimension", "$value": "12px" },
    "md": { "$type": "dimension", "$value": "20px" },
    "lg": { "$type": "dimension", "$value": "40px" }
  },
  "motion": {
    "fast":            { "$type": "duration", "$value": "150ms" },
    "base":            { "$type": "duration", "$value": "300ms" },
    "slow":            { "$type": "duration", "$value": "520ms" },
    "ease":            { "$type": "cubicBezier", "$value": "cubic-bezier(0.16, 1, 0.3, 1)" },
    "pressScale":      { "$type": "number", "$value": 0.95 },
    "disabledOpacity": { "$type": "number", "$value": 0.5 }
  }
}

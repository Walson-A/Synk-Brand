{
  "name": "@synk/brand",
  "version": "0.5.0",
  "description": "SYNK brand assets — logo, animated logo component, and design tokens. Single source of truth shared by the website and the app.",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": "./src/index.js",
    "./animation": {
      "types": "./src/animation/SynkLogoAnim.native.d.ts",
      "react-native": "./src/animation/SynkLogoAnim.native.jsx",
      "default": "./src/animation/SynkLogoAnim.jsx"
    },
    "./animation/native": {
      "types": "./src/animation/SynkLogoAnim.native.d.ts",
      "default": "./src/animation/SynkLogoAnim.native.jsx"
    },
    "./tokens": {
      "types": "./src/tokens.d.ts",
      "default": "./src/tokens.js"
    },
    "./tokens.css": "./src/tokens.css",
    "./logo/*": "./src/logo/*",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "tokens",
    "README.md",
    "CHANGELOG.md",
    "ADOPTION.md"
  ],
  "scripts": {
    "build:tokens": "style-dictionary build --config tokens/style-dictionary.config.mjs",
    "test": "echo \"(no tests yet)\" && exit 0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "style-dictionary": "^4.0.0"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Walson-A/Synk-Brand.git"
  }
}
